# Required for agent chat
ANTHROPIC_API_KEY=sk-ant-...

# BSV server wallet for on-chain posting (OP_RETURN)
# Generate with: node scripts/generate-wallet.mjs
# Fund the address with ~10,000 sats (~$0.005) for thousands of posts
# If not set, posts are saved to DB only (no on-chain logging)
BSV_SERVER_WIF=

# Database path (defaults to ./local.db if not set)
# For Railway: /data/local.db
DATABASE_PATH=

# Port (Railway sets this automatically)
PORT=3000
